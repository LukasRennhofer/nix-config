* {
  /* Gruvbox Dark Theme */
  bg0       : #282828;
  bg1       : #3c3836;
  bg2       : #504945;
  bg3       : #665c54;
  fg0       : #ebdbb2;
  fg1       : #d5c4a1;
  fg2       : #7c6f64;
  red       : #cc241d;
  green     : #98971a;
  yellow    : #d79921;
  blue      : #83a598;
  magenta   : #b16286;
  cyan      : #689d6a;

  accent: @yellow;
  urgent: @red;
}
